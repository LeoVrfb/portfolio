---
import ProjectGallery from "./ProjectGallery.astro";

interface Props {
  mediaType?: string;
  images?: { src: string; alt: string }[];
  videoUrl?: string;
  img?: string;
  img_alt?: string;
}

const { mediaType, images, videoUrl, img, img_alt } = Astro.props;
---

{
  mediaType === "carousel" && images ? (
    <>
      <!-- Version mobile : première image uniquement -->
      <div class="md:hidden relative w-full h-full rounded-xl shadow-2xl">
       
          <img
            src={images[0].src}
            alt={images[0].alt || ""}
            class="w-full h-full object-cover object-top rounded-xl"
            loading="eager"
          />

      </div>

      <!-- Version desktop : carousel -->
      <div class="hidden md:block">
        <ProjectGallery images={images} />
      </div>
    </>
  ) : mediaType === "video" ? (
    <div class="aspect-video w-full rounded-2xl overflow-hidden shadow-2xl">
      <video
        class="w-full h-full object-cover"
        src={videoUrl}
        controls
        autoplay
        muted
        loop
      />
    </div>
  ) : (
    img && (
      <div class="relative w-full h-[400px] p-4 bg-gradient-to-r from-gray-900 to-gray-800 border border-white/10 rounded-xl shadow-2xl">
        <div class="group relative h-full rounded-xl overflow-hidden shadow-2xl border border-white/10">
          <img
            src={img.startsWith("/") ? img : `/${img}`}
            alt={img_alt || ""}
            class="w-full h-full object-cover object-top"
            loading="eager"
          />
        </div>
      </div>
    )
  )
}

<style>
  img {
    opacity: 0;
    animation: fadeIn 0.5s ease-in forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
