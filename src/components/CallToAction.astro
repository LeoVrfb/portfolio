---
const { href } = Astro.props;
---

<a href={href} class="call-to-action">
  <slot />
</a>

<style>
  .call-to-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    border-radius: 50px;
    background: linear-gradient(90deg, #6a11cb 0%, #2575fc 100%);
    color: white;
    text-decoration: none;
    font-weight: bold;
    font-size: 1.1rem;
    transition:
      transform 0.3s,
      box-shadow 0.3s;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .call-to-action:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3);
  }

  .call-to-action:active {
    transform: translateY(0);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
  }

  .call-to-action svg {
    margin-left: 0.5rem; /* Espace entre le texte et l'icône */
  }
</style>
