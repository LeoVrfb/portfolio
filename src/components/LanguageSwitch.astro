---
import { getLangFromUrl } from "../i18n/utils";

const currentLang = getLangFromUrl(Astro.url);
const targetLang = currentLang === "fr" ? "en" : "fr";

// Obtenir le chemin actuel
const currentPath = Astro.url.pathname;

// Gérer les cas spéciaux
let newPath;
if (currentPath === "/" || currentPath === "") {
  newPath = `/${targetLang}`;
} else {
  newPath = currentPath.replace(`/${currentLang}/`, `/${targetLang}/`);
  if (newPath === currentPath) {
    newPath = `/${targetLang}`;
  }
}
---

<a
  href={newPath}
  class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-white
  bg-gradient-to-br from-gray-800/80 to-gray-900/80
  rounded-full
  border border-gray-500/50
  shadow-lg
  -webkit-backdrop-filter backdrop-filter backdrop-blur-sm
  transform-gpu
  transition-all duration-200 ease-in-out
  hover:shadow-xl hover:border-gray-400/50 hover:-translate-y-0.5 hover:from-gray-700 hover:to-gray-800
  active:translate-y-0 active:shadow-md
  will-change-transform"
>
  {
    currentLang === "fr" ? (
      <>
        <img
          src="/assets/englishflag.webp"
          alt="English"
          class="w-5 h-5 rounded-full shadow-sm"
        />
        <span>EN</span>
      </>
    ) : (
      <>
        <img
          src="/assets/frenchflag.webp"
          alt="Français"
          class="w-5 h-5 rounded-full shadow-sm"
        />
        <span>FR</span>
      </>
    )
  }
</a>
