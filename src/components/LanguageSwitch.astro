---
import { getLangFromUrl } from "../i18n/utils";

const currentLang = getLangFromUrl(Astro.url);
const targetLang = currentLang === "fr" ? "en" : "fr";

// Obtenir le chemin actuel
const currentPath = Astro.url.pathname;

// Gérer les cas spéciaux
let newPath;
if (currentPath === "/" || currentPath === "") {
  // Si on est à la racine, rediriger vers la langue cible
  newPath = `/${targetLang}`;
} else {
  // Sinon, remplacer la langue dans le chemin
  newPath = currentPath.replace(`/${currentLang}/`, `/${targetLang}/`);
  // Si le remplacement n'a pas fonctionné, c'est qu'on est sur une page sans langue
  if (newPath === currentPath) {
    newPath = `/${targetLang}`;
  }
}
---

<a
  href={newPath}
  class="inline-flex items-center justify-center px-4 py-2 text-sm font-semibold text-white bg-gradient-to-br from-gray-800 to-gray-900 rounded-full border border-gray-700 shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200 ease-in-out hover:from-gray-700 hover:to-gray-800 active:translate-y-0 active:shadow-md"
>
  {currentLang === "fr" ? "EN" : "FR"}
</a>
