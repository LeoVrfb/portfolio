---
import type { CollectionEntry } from "astro:content";
import {
  FaCheckCircle,
  FaTimesCircle,
  FaArrowRight,
  FaCrown,
} from "react-icons/fa";

interface Props {
  services: CollectionEntry<"service">[];
}

const { services } = Astro.props;

const getMissingFeatures = (currentService: CollectionEntry<"service">) => {
  if (currentService.data.title === "Landing Page") {
    const siteVitrine = services.find((s) => s.data.title === "Site Vitrine");
    return siteVitrine
      ? siteVitrine.data.features.filter(
          (feature: string) => !currentService.data.features.includes(feature)
        )
      : [];
  }

  if (currentService.data.title === "Site Vitrine") {
    const ecommerce = services.find((s) => s.data.title === "Site E-commerce");
    return ecommerce
      ? ecommerce.data.features.filter(
          (feature: string) => !currentService.data.features.includes(feature)
        )
      : [];
  }
  return [];
};
---

<div class="py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        services.map((service) => (
          <div
            class={`relative group overflow-hidden rounded-2xl backdrop-blur-lg transition-transform duration-300 hover:scale-[1.01] cursor-pointer
            ${
              service.data.is_best_deal
                ? "bg-gradient-to-br from-purple-500/20 to-indigo-500/20 border-2 border-purple-400/50"
                : "bg-white/10 border border-white/10"
            }`}
            data-slug={service.data.id}
          >
            {service.data.is_best_deal && (
              <div class="absolute top-2 right-2 sm:right-4 md:right-3">
                <span class="inline-flex items-center gap-1 bg-gradient-to-r from-yellow-400 to-orange-500 text-purple-900 px-4 py-1 rounded-full text-sm font-semibold shadow-lg scale-[0.70] sm:scale-[0.75] md:scale-[0.95]">
                  <FaCrown className="text-purple-900" /> Best Deal
                </span>
              </div>
            )}

            <div class="p-8 pb-28 relative h-full">
              <div class="text-center mb-8">
                <h2 class="text-2xl font-bold text-white mb-4">
                  {service.data.title}
                </h2>
                <div class="text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-pink-300">
                  {service.data.price}€
                </div>
              </div>

              <ul class="space-y-4 mb-4">
                {service.data.features.map((feature: string) => (
                  <li class="flex items-start gap-3 group">
                    <FaCheckCircle
                      className="text-green-400 flex-shrink-0 mt-1 transform group-hover:scale-110 transition-transform"
                      size="1.2em"
                    />
                    <span class="text-purple-100">{feature}</span>
                  </li>
                ))}
                {getMissingFeatures(service).map((feature: string) => (
                  <li class="flex items-start gap-3 opacity-50">
                    <FaTimesCircle
                      className="text-red-400 flex-shrink-0 mt-1"
                      size="1.2em"
                    />
                    <span class="text-purple-200">{feature}</span>
                  </li>
                ))}
              </ul>

              <div class="absolute bottom-10 left-0 right-0 px-8">
                <a
                  href={`/services/${service.data.id}`}
                  class={`flex items-center justify-between w-full px-6 py-3 rounded-lg transition-all duration-300
                  ${
                    service.data.is_best_deal
                      ? "bg-gradient-to-r from-purple-500 to-indigo-600 hover:from-purple-600 hover:to-indigo-700 text-white shadow-lg hover:shadow-xl"
                      : "bg-white/10 hover:bg-white/20 text-white"
                  }`}
                >
                  <span>Découvrir {service.data.title}</span>
                  <div class="bg-white/10 w-8 h-8 rounded-full flex items-center justify-center group-hover:bg-white/20 transition-colors">
                    <FaArrowRight className="text-white" />
                  </div>
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  function handleSectionClick(slug: string) {
    window.location.href = `/services/${slug}`;
  }

  document.addEventListener("DOMContentLoaded", function () {
    const sections = document.querySelectorAll("[data-slug]");
    sections.forEach((section) => {
      const slug = section.getAttribute("data-slug");
      if (slug) {
        section.addEventListener("click", () => handleSectionClick(slug));
      }
    });
  });
</script>
