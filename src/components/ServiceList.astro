---
import type { CollectionEntry } from "astro:content";
import { getLangFromUrl } from "../i18n/utils";
import {
  FaCheckCircle,
  FaTimesCircle,
  FaArrowRight,
  FaCrown,
} from "react-icons/fa";

interface Props {
  services: CollectionEntry<"service">[];
}

const { services } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const getMissingFeatures = (currentService: CollectionEntry<"service">) => {
  if (currentService.data.order === 1) {
    const siteVitrine = services.find((s) => s.data.order === 2);
    return siteVitrine
      ? siteVitrine.data.features.filter(
          (feature: string) => !currentService.data.features.includes(feature)
        )
      : [];
  }

  if (currentService.data.order === 2) {
    const ecommerce = services.find((s) => s.data.order === 3);
    return ecommerce
      ? ecommerce.data.features.filter(
          (feature: string) => !currentService.data.features.includes(feature)
        )
      : [];
  }
  return [];
};
---

<div class="lg:py-16 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        services.map((service) => (
          <div
            class={`relative group overflow-hidden rounded-xl backdrop-blur-lg transition-transform duration-300 hover:scale-[1.01] cursor-pointer ${
              service.data.is_best_deal ? "wp-card-featured" : "wp-card"
            }`}
            data-slug={service.id.split("/")[1].replace(".md", "")}
          >
            {service.data.is_best_deal && (
              <div class="absolute top-2 right-2 sm:right-4 md:right-3">
                <span class="wp-badge inline-flex items-center gap-1 px-4 py-1 rounded-full text-sm font-semibold shadow-lg scale-[0.70] sm:scale-[0.75] md:scale-[0.95]">
                  <FaCrown /> Best Deal
                </span>
              </div>
            )}

            <div class="p-8 pt-10 pb-28 relative h-full">
              <div class="text-center mb-8">
                <h2 class="text-2xl font-bold wp-title mb-4">
                  {service.data.title}
                </h2>
                <div class="text-4xl font-bold wp-price">
                  {service.data.price}€
                </div>
              </div>

              <ul class="space-y-4 mb-4">
                {service.data.features.map((feature: string) => (
                  <li class="flex items-start gap-3 group">
                    <FaCheckCircle
                      className="wp-feature-icon-check flex-shrink-0 mt-1 transform group-hover:scale-110 transition-transform"
                      size="1.2em"
                    />
                    <span class="wp-feature-text">{feature}</span>
                  </li>
                ))}
                {getMissingFeatures(service).map((feature: string) => (
                  <li class="flex items-start gap-3 wp-feature-disabled">
                    <FaTimesCircle
                      className="wp-feature-icon-times flex-shrink-0 mt-1"
                      size="1.2em"
                    />
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>

              <div class="absolute bottom-10 left-0 right-0 px-8">
                <a
                  href={`/${lang}/services/${service.id.split("/")[1].replace(".md", "")}`}
                  class={`flex items-center justify-between w-full px-6 py-3 rounded-lg transition-all duration-300 ${
                    service.data.is_best_deal ? "wp-button" : "wp-button-simple"
                  }`}
                >
                  <span>Découvrir {service.data.title}</span>
                  <div class="bg-white/10 w-8 h-8 rounded-full flex items-center justify-center group-hover:bg-white/20 transition-colors">
                    <FaArrowRight />
                  </div>
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .wp-card {
    background-color: var(--wp-card-bg);
  }

  .wp-card-featured {
    background: linear-gradient(
      to bottom right,
      var(--wp-card-featured-from),
      var(--wp-card-featured-to)
    );
    border: 1px solid var(--wp-card-featured-border);
  }

  .wp-title {
    color: var(--wp-title);
  }

  .wp-price {
    background: linear-gradient(
      to right,
      var(--wp-price-from),
      var(--wp-price-to)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .wp-feature-text {
    color: var(--wp-feature-text);
  }

  .wp-feature-icon-check {
    color: var(--wp-feature-icon-check);
  }

  .wp-feature-icon-times {
    color: var(--wp-feature-icon-times);
  }

  .wp-feature-disabled {
    opacity: 0.5;
  }

  .wp-badge {
    background: linear-gradient(
      to right,
      var(--wp-badge-from),
      var(--wp-badge-to)
    );
    color: var(--wp-badge-text);
  }

  .wp-button {
    background: linear-gradient(
      to right,
      var(--wp-button-from),
      var(--wp-button-to)
    );
    color: var(--wp-button-text);
  }

  .wp-button:hover {
    background: linear-gradient(
      to right,
      var(--wp-button-hover-from),
      var(--wp-button-hover-to)
    );
  }

  .wp-button-simple {
    background-color: var(--wp-button-simple-bg);
    color: var(--wp-button-text);
  }

  .wp-button-simple:hover {
    background-color: var(--wp-button-simple-hover);
  }
</style>

<script define:vars={{ lang }}>
  function handleSectionClick(slug) {
    window.location.href = `/${lang}/services/${slug.replace(".md", "")}`;
  }

  document.addEventListener("DOMContentLoaded", function () {
    const sections = document.querySelectorAll("[data-slug]");
    sections.forEach((section) => {
      const slug = section.getAttribute("data-slug");
      if (slug) {
        section.addEventListener("click", () => handleSectionClick(slug));
      }
    });
  });
</script>
