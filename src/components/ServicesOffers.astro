---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import {
  FaWordpress,
  FaCode,
  FaArrowRight,
  FaRocket,
  FaPaintBrush,
  FaCogs,
} from "react-icons/fa";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Solution Standard -->
      <a
        href={`/${lang}/servicesWordpress`}
        class="group relative h-full block transition-transform duration-300 hover:scale-[1.02]"
      >
        <div class="absolute inset-0 standard-gradient rounded-2xl"></div>
        <div
          class="relative h-full overflow-hidden rounded-2xl backdrop-blur-sm standard-card"
        >
          <div class="p-8 h-full flex flex-col">
            <div
              class="standard-icon-container flex items-center justify-center w-16 h-16 rounded-xl mb-6 mx-auto shadow-lg"
            >
              <FaWordpress className="w-8 h-8 text-white" />
            </div>

            <h3 class="text-2xl font-bold standard-title text-center mb-4">
              {t("servicesOffers.standardSolution")}
            </h3>

            <div class="text-center space-y-2 mb-6">
              <div
                class="standard-tag inline-flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300"
              >
                <FaWordpress className="w-5 h-5 standard-tag-accent" />
                <span class="standard-tag-text font-medium">WordPress</span>
                <span class="standard-tag-accent">+</span>
                <div
                  class="w-5 h-5 rounded-full border-2 standard-tag-border flex items-center justify-center"
                >
                  <span class="standard-tag-accent font-bold text-sm">D</span>
                </div>
                <span class="standard-tag-text font-medium">Divi</span>
              </div>
            </div>

            <div class="space-y-4 mb-8">
              <div class="flex items-center gap-3 standard-feature">
                <FaRocket className="flex-shrink-0 standard-feature-icon" />
                <span>{t("servicesOffers.standardDescription")}</span>
              </div>
              <div class="flex items-center gap-3 standard-feature">
                <FaPaintBrush className="flex-shrink-0 standard-feature-icon" />
                <span>{t("servicesOffers.standardFeatures.0")}</span>
              </div>
              <div class="flex items-center gap-3 standard-feature">
                <FaCogs className="flex-shrink-0 standard-feature-icon" />
                <span>{t("servicesOffers.standardFeatures.1")}</span>
              </div>
            </div>

            <div class="text-center mb-8">
              <div class="text-sm standard-tag-text mb-2">
                {t("servicesOffers.standardPrice")}
              </div>
              <div class="text-4xl font-bold standard-price">
                {t("servicesOffers.standardPriceValue")}
              </div>
            </div>

            <div
              class="standard-button flex items-center justify-between w-full px-6 py-4 rounded-xl text-white shadow-lg group-hover:shadow-xl transition-all duration-300 mt-auto"
            >
              <span class="font-semibold"
                >{t("servicesOffers.discoverOffers")}</span
              >
              <div
                class="bg-white/10 w-8 h-8 rounded-full flex items-center justify-center group-hover:bg-white/20 transition-all duration-300 transform group-hover:translate-x-1"
              >
                <FaArrowRight />
              </div>
            </div>
          </div>
        </div>
      </a>

      <!-- Solution Sur Mesure -->
      <a
        href={`/${lang}/devis`}
        class="group relative h-full block transition-transform duration-300 hover:scale-[1.02]"
      >
        <div class="absolute inset-0 custom-gradient rounded-2xl"></div>
        <div
          class="relative h-full overflow-hidden rounded-2xl backdrop-blur-sm custom-card"
        >
          <div class="p-8 h-full flex flex-col">
            <div
              class="custom-icon-container flex items-center justify-center w-16 h-16 rounded-xl mb-6 mx-auto shadow-lg"
            >
              <FaCode className="w-8 h-8 text-white" />
            </div>

            <h3 class="text-2xl font-bold custom-title text-center mb-4">
              {t("servicesOffers.customSolution")}
            </h3>

            <div class="text-purple-200 text-center mb-6">
              <div
                class="custom-tag inline-flex items-center gap-2 px-4 py-2 rounded-full transition-all duration-300"
              >
                {t("servicesOffers.customDescription")}
              </div>
            </div>

            <div class="space-y-4 mb-8">
              <div class="flex items-center gap-3 custom-feature">
                <FaRocket className="flex-shrink-0 custom-feature-icon" />
                <span>{t("servicesOffers.customFeatures.0")}</span>
              </div>
              <div class="flex items-center gap-3 custom-feature">
                <FaPaintBrush className="flex-shrink-0 custom-feature-icon" />
                <span>{t("servicesOffers.customFeatures.1")}</span>
              </div>
              <div class="flex items-center gap-3 custom-feature">
                <FaCogs className="flex-shrink-0 custom-feature-icon" />
                <span>{t("servicesOffers.customFeatures.1")}</span>
              </div>
            </div>

            <div class="text-center mb-8">
              <div class="standard-tag-text font-medium">
                {t("servicesOffers.complexProject")}
              </div>
              <div class="text-2xl font-bold custom-price">
                {t("servicesOffers.customQuoteValue")}
              </div>
            </div>

            <div
              class="custom-button flex items-center justify-between w-full px-6 py-4 rounded-xl text-white shadow-lg group-hover:shadow-xl transition-all duration-300 mt-auto"
            >
              <span class="font-semibold"
                >{t("servicesOffers.customQuote")}</span
              >
              <div
                class="bg-white/10 w-8 h-8 rounded-full flex items-center justify-center group-hover:bg-white/20 transition-all duration-300 transform group-hover:translate-x-1"
              >
                <FaArrowRight />
              </div>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>
</div>

<style>
  /* Standard offer styles */
  .standard-gradient {
    background: linear-gradient(
      to right,
      var(--standard-gradient-bg-from),
      var(--standard-gradient-bg-to)
    );
  }

  .standard-card {
    background-color: var(--standard-card-bg);
    border: 1px solid var(--standard-card-border);
  }

  .standard-icon-container {
    background: linear-gradient(
      to bottom right,
      var(--standard-icon-from),
      var(--standard-icon-to)
    );
  }

  .standard-title {
    color: var(--standard-title);
  }

  .standard-tag {
    background: linear-gradient(
      to right,
      var(--standard-tag-bg-from),
      var(--standard-tag-bg-to)
    );
    border: 1px solid var(--standard-tag-border);
  }

  .standard-tag-text {
    color: var(--standard-tag-text);
  }

  .standard-tag-accent {
    color: var(--standard-tag-accent);
  }

  .standard-feature {
    color: var(--standard-feature-text);
  }

  .standard-feature-icon {
    color: var(--standard-feature-icon);
  }

  .standard-price {
    background: linear-gradient(
      to right,
      var(--standard-price-gradient-from),
      var(--standard-price-gradient-to)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .standard-button {
    background: linear-gradient(
      to right,
      var(--standard-button-from),
      var(--standard-button-to)
    );
  }

  .group:hover .standard-button {
    background: linear-gradient(
      to right,
      var(--standard-button-hover-from),
      var(--standard-button-hover-to)
    );
  }

  /* Custom offer styles */
  .custom-gradient {
    background: linear-gradient(
      to right,
      var(--custom-gradient-bg-from),
      var(--custom-gradient-bg-to)
    );
  }

  .custom-card {
    background-color: var(--custom-card-bg);
    border: 1px solid var(--custom-card-border);
  }

  .custom-icon-container {
    background: linear-gradient(
      to bottom right,
      var(--custom-icon-from),
      var(--custom-icon-to)
    );
  }

  .custom-title {
    color: var(--custom-title);
  }

  .custom-tag {
    background: linear-gradient(
      to right,
      var(--custom-tag-bg-from),
      var(--custom-tag-bg-to)
    );
    border: 1px solid var(--custom-tag-border);
    color: var(--custom-tag-text);
  }

  .custom-tag-text {
    color: var(--custom-tag-text);
  }

  .custom-tag-accent {
    color: var(--custom-tag-accent);
  }

  .custom-feature {
    color: var(--custom-feature-text);
  }

  .custom-feature-icon {
    color: var(--custom-feature-icon);
  }

  .custom-price {
    background: linear-gradient(
      to right,
      var(--custom-price-gradient-from),
      var(--custom-price-gradient-to)
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .custom-button {
    background: linear-gradient(
      to right,
      var(--custom-button-from),
      var(--custom-button-to)
    );
  }

  .group:hover .custom-button {
    background: linear-gradient(
      to right,
      var(--custom-button-hover-from),
      var(--custom-button-hover-to)
    );
  }
</style>

<script define:vars={{ lang }}>
  function handleSectionClick(slug) {
    window.location.href = `/${lang}/services/${slug}`;
  }

  document.addEventListener("DOMContentLoaded", function () {
    const sections = document.querySelectorAll("[data-slug]");
    sections.forEach((section) => {
      const slug = section.getAttribute("data-slug");
      if (slug) {
        section.addEventListener("click", () => handleSectionClick(slug));
      }
    });
  });
</script>
