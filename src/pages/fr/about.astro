---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import Hero from "../../components/Hero.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={`${t("about.title")} | Léo Hengebaert`}
  description={t("about.description") as string}
>
  <div class="stack gap-20">
    <main class="wrapper about">
      <Hero
        title={t("about.title") as string}
        tagline={t("about.tagline") as string}
      >
        <img
          width="1553"
          height="873"
          src="/assets/portraitLeo.jpg"
          alt={t("about.img-alt") as string}
        />
      </Hero>

      <section>
        <h2 class="section-title">{t("about.sections.about.title")}</h2>
        <div class="content">
          <p>{t("about.sections.about.p1")}</p>
          <p>{t("about.sections.about.p2")}</p>
          <p>{t("about.sections.about.p3")}</p>
          <p>{t("about.sections.about.p4")}</p>
          <p>{t("about.sections.about.p5")}</p>
          <br />
        </div>
      </section>

      <section>
        <h2 class="section-title">{t("about.sections.education.title")}</h2>
        <div class="content">
          <p>{t("about.sections.education.content")}</p>
        </div>
      </section>

      <section>
        <h2 class="section-title">{t("about.sections.skills.title")}</h2>
        <div class="content">
          <ol>
            <li>
              {t("about.sections.skills.technical.title")}
              <ul>
                {
                  (t("about.sections.skills.technical.items") as string[]).map(
                    (item: string) => <li>{item}</li>
                  )
                }
              </ul>
            </li>
            <li>
              {t("about.sections.skills.professional.title")}
              <ul>
                {
                  (
                    t("about.sections.skills.professional.items") as string[]
                  ).map((item: string) => <li>{item}</li>)
                }
              </ul>
            </li>
            <li>
              {t("about.sections.skills.languages.title")}
              <ul>
                {
                  (t("about.sections.skills.languages.items") as string[]).map(
                    (item: string) => <li>{item}</li>
                  )
                }
              </ul>
            </li>
          </ol>
        </div>
      </section>

      <ContactCTA />
    </main>
  </div>
</BaseLayout>
<style>
  .about {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* Hero Section */
  img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    border-radius: 24px;
    margin: 2rem 0;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  /* Content Grid Layout */
  .content-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 4rem;
    margin-top: 6rem;
  }

  section {
    grid-column: span 12;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border-radius: 24px;
    padding: 3rem;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 3%;
  }

  /* Modern gradient backgrounds for sections */
  section:nth-child(1) {
    background: linear-gradient(
      145deg,
      rgba(79, 70, 229, 0.1),
      rgba(0, 0, 0, 0)
    );
  }
  section:nth-child(2) {
    background: linear-gradient(
      145deg,
      rgba(236, 72, 153, 0.1),
      rgba(0, 0, 0, 0)
    );
  }
  section:nth-child(3) {
    background: linear-gradient(
      145deg,
      rgba(34, 211, 238, 0.1),
      rgba(0, 0, 0, 0)
    );
  }
  section:nth-child(4) {
    background: linear-gradient(
      145deg,
      rgba(16, 185, 129, 0.1),
      rgba(0, 0, 0, 0)
    );
  }

  /* Section Title Styling */
  .section-title {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }

  /* Different gradients for each section title */
  section:nth-child(1) .section-title {
    background: linear-gradient(90deg, #4f46e5, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  section:nth-child(2) .section-title {
    background: linear-gradient(90deg, #ec4899, #f472b6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  section:nth-child(3) .section-title {
    background: linear-gradient(90deg, #22d3ee, #67e8f9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  section:nth-child(4) .section-title {
    background: linear-gradient(90deg, #10b981, #34d399);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Decorative line under titles */
  .section-title::after {
    content: "";
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 60px;
    height: 4px;
    border-radius: 2px;
  }

  section:nth-child(1) .section-title::after {
    background: #4f46e5;
  }
  section:nth-child(2) .section-title::after {
    background: #ec4899;
  }
  section:nth-child(3) .section-title::after {
    background: #22d3ee;
  }
  section:nth-child(4) .section-title::after {
    background: #10b981;
  }

  /* Content Styling */
  .content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--gray-200);
  }

  .content p {
    margin-bottom: 1.8rem;
  }

  /* Skills Layout */
  .skills-grid {
    display: grid;
    gap: 2rem;
  }

  .skills-grid ol {
    list-style: none;
    padding: 0;
  }

  .skills-grid li {
    margin-bottom: 2rem;
  }

  .skills-grid ul {
    margin-top: 0.8rem;
    padding-left: 1.5rem;
  }

  .skills-grid ul li {
    margin-bottom: 0.8rem;
    position: relative;
  }

  .skills-grid ul li::before {
    content: "→";
    position: absolute;
    left: -1.5rem;
    color: #22d3ee;
  }

  /* Desktop Layout */
  @media (min-width: 1024px) {
    section {
      grid-column: 3 / span 8;
    }

    .about {
      padding: 4rem;
    }

    section:hover {
      transform: translateY(-5px);
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
    }

    /* Alternating sections layout */
    section:nth-child(odd) {
      grid-column: 2 / span 6;
    }

    section:nth-child(even) {
      grid-column: 6 / span 6;
    }
  }

  /* Tablet Layout */
  @media (min-width: 768px) and (max-width: 1023px) {
    section {
      grid-column: 2 / span 10;
    }

    .about {
      padding: 3rem;
    }
  }

  /* Mobile Layout */
  @media (max-width: 767px) {
    .about {
      padding: 1rem;
    }

    img {
      height: 300px;
    }

    .section-title {
      font-size: 2.2rem;
    }

    section {
      padding: 2rem;
    }

    .content-grid {
      gap: 3rem;
    }
  }

  /* Animation for content loading */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section {
    animation: fadeIn 0.8s ease-out forwards;
  }

  section:nth-child(2) {
    animation-delay: 0.3s;
  }
  section:nth-child(3) {
    animation-delay: 0.6s;
  }
  section:nth-child(4) {
    animation-delay: 0.9s;
  }
</style>
