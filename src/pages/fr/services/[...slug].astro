---
import { type CollectionEntry, getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ContactCTA from "../../../components/ContactCTA.astro";
import Hero from "../../../components/Hero.astro";
import Icon from "../../../components/Icon.astro";
import {
  FaStar,
  FaBriefcase,
  FaCheckCircle,
  FaArrowRight,
} from "react-icons/fa";
import { FiFileText } from "react-icons/fi";
import { HiOutlineDocument } from "react-icons/hi2";
import { HiPlusCircle } from "react-icons/hi2";

interface Props {
  entry: CollectionEntry<"service">;
}

export const prerender = true;

// Get only French service entries
export async function getStaticPaths() {
  const lang = "fr";
  const services = await getCollection("service", ({ id }) => {
    return id.startsWith(`${lang}/`);
  });

  return services.map((entry) => ({
    params: { slug: entry.id.split("/")[1] }, // Remove language prefix from slug
    props: { entry },
  }));
}

const { entry } = Astro.props;
const formId = entry.data.form_id || "contactForm";
let isSubmitting = false;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
      <!-- En-tête avec navigation -->
      <nav class="mb-8">
        <a
          href="/fr/servicesWordpress"
          class="inline-flex items-center service-nav-link"
        >
          <Icon icon="arrow-left" />
          <span class="ml-2">Retour aux services</span>
        </a>
      </nav>

      <!-- Hero Section -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold service-title mb-6">
          {entry.data.title}
        </h1>
        <p class="service-description max-w-2xl mx-auto">
          {entry.data.description}
        </p>
      </div>

      <!-- Contenu Principal -->
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <!-- Colonne de gauche : Description du service -->
        <div class="space-y-8 order-1">
          {
            entry.data.service_details.map((detail: any) => (
              <div class="service-card">
                {detail.title && (
                  <h2 class="text-2xl font-bold flex items-center gap-4 mb-6 service-card-title">
                    {detail.title.includes("Pourquoi") ? (
                      <FaStar className="service-icon-star" size="1.5em" />
                    ) : (
                      <FaBriefcase
                        className="service-icon-briefcase "
                        size="1.2em"
                      />
                    )}

                    {detail.title}
                  </h2>
                )}
                {detail.content && (
                  <div class="service-card-text leading-relaxed mb-6">
                    {detail.content.split("\n").map((line) => {
                      if (line.trim().startsWith("→")) {
                        return (
                          <p class="flex items-start gap-2 ml-4 mb-2">
                            <span class="text-purple-400 text-lg w-5 h-5 flex items-center mt-1">
                              →
                            </span>
                            <span>{line.trim().substring(1)}</span>
                          </p>
                        );
                      } else if (
                        line.trim().startsWith("•") &&
                        line.includes("€")
                      ) {
                        return (
                          <p class="flex items-start gap-2 ml-4 mb-2">
                            <HiPlusCircle className="text-emerald-400 w-5 h-5 flex-shrink-0" />
                            <span>{line.trim().substring(1)}</span>
                          </p>
                        );
                      } else if (line.trim().startsWith("•")) {
                        return (
                          <p class="flex items-start gap-2 ml-4 mb-2">
                            <HiOutlineDocument className="text-sky-300 w-5 h-5 flex-shrink-0" />
                            <span>{line.trim().substring(1)}</span>
                          </p>
                        );
                      }
                      return <p class="mb-4">{line}</p>;
                    })}
                  </div>
                )}
                {detail.list_items && (
                  <ul class="space-y-4">
                    {detail.list_items.map((item: string) => (
                      <li class="flex items-start gap-4 group">
                        <FaCheckCircle
                          className="service-icon-check flex-shrink-0 mt-1 transform group-hover:scale-110 transition-transform"
                          size="1.2em"
                        />
                        <span
                          set:html={item.replace(
                            /\*\*(.*?)\*\*/g,
                            '<strong class="font-semibold">$1</strong>'
                          )}
                        />
                      </li>
                    ))}
                  </ul>
                )}
                {detail.extra_options && (
                  <div class="space-y-2 mb-6">
                    {detail.extra_options.map((item) => (
                      <p class="flex items-start gap-2 ml-4">
                        <HiPlusCircle className="text-cyan-400 w-5 h-5 flex-shrink-0 mt-0.5" />
                        <span
                          set:html={item.replace(
                            /\*\*(.*?)\*\*/g,
                            '<strong class="font-semibold">$1</strong>'
                          )}
                        />
                      </p>
                    ))}
                  </div>
                )}
                {detail.note && (
                  <p class="text-sm italic mt-2 mb-6">{detail.note}</p>
                )}
                {detail.use_cases && (
                  <div class="space-y-2 mb-6">
                    {detail.use_cases.map((item) => (
                      <p class="flex items-start gap-2 ml-4">
                        <span class="text-purple-400 text-lg w-5 h-5 flex items-center mt-1">
                          →
                        </span>
                        <span>{item}</span>
                      </p>
                    ))}
                  </div>
                )}
                {detail.pages && (
                  <div class="space-y-2 mb-6">
                    {detail.pages.map((item) => (
                      <p class="flex items-start gap-2 ml-4">
                        <HiOutlineDocument className="text-yellow-200  w-5 h-5 flex-shrink-0 mt-0.5" />
                        <span
                          set:html={item.replace(
                            /\*\*(.*?)\*\*/g,
                            '<strong class="font-semibold">$1</strong>'
                          )}
                        />
                      </p>
                    ))}
                  </div>
                )}
              </div>
            ))
          }
        </div>

        <!-- Colonne de droite : Formulaire -->
        <div class="order-2 lg:sticky lg:top-8">
          <div class="service-form">
            <!-- Conteneur du formulaire -->
            <div id="formContainer">
              <h3 class="text-2xl font-bold service-form-title mb-6">
                Commencez votre projet
              </h3>
              <form id={formId} class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                  <input
                    type="text"
                    name="name"
                    placeholder="Prénom*"
                    required
                    class="service-form-input col-span-1"
                  />
                  <input
                    type="text"
                    name="surname"
                    placeholder="Nom*"
                    required
                    class="service-form-input col-span-1"
                  />
                </div>
                <input
                  type="email"
                  name="email"
                  placeholder="Adresse Email*"
                  required
                  class="service-form-input"
                />
                <input
                  type="tel"
                  name="phone"
                  placeholder="Numéro de Téléphone*"
                  required
                  class="service-form-input"
                />
                <textarea
                  name="message"
                  placeholder="Votre message*"
                  required
                  class="service-form-input h-32 resize-none"></textarea>
                <button
                  type="submit"
                  class="service-form-button"
                  disabled={isSubmitting}
                >
                  {
                    isSubmitting ? (
                      <div class="flex items-center gap-2">
                        <div class="loader" />
                        <span>Envoi en cours...</span>
                      </div>
                    ) : (
                      <>
                        <span>Envoyer votre demande</span>
                        <FaArrowRight />
                      </>
                    )
                  }
                </button>
              </form>
            </div>

            <!-- Message de succès (caché par défaut) -->
            <div id="successMessage" class="hidden">
              <div class="text-center py-8 space-y-4">
                <FaCheckCircle
                  className="service-success-icon w-16 h-16 mx-auto"
                />
                <h3 class="text-2xl font-bold service-success-title">
                  Message envoyé avec succès !
                </h3>
                <p class="service-success-text">
                  Merci pour votre intérêt. Nous avons bien reçu votre message
                  et nous vous répondrons dans les plus brefs délais.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Navigation */
  .service-nav-link {
    color: var(--service-nav-text);
  }
  .service-nav-link:hover {
    color: var(--service-nav-hover);
  }

  /* Hero */
  .service-title {
    color: var(--service-title);
  }
  .service-description {
    color: var(--service-description);
  }

  /* Cards */
  .service-card {
    background-color: var(--service-card-bg);
    backdrop-filter: blur(12px);
    border-radius: 1rem;
    border: 1px solid var(--service-card-border);
    padding: 2rem;
    transform: scale(1);
    transition: all 0.3s;
  }
  .service-card:hover {
    background-color: var(--service-card-hover);
    transform: scale(1.02);
  }
  .service-card-title {
    color: var(--service-card-title);
  }
  .service-card-text {
    color: var(--service-card-text);
  }
  .service-icon-star {
    color: var(--service-icon-star);
  }
  .service-icon-briefcase {
    color: var(--service-icon-briefcase);
  }
  .service-icon-check {
    color: var(--service-icon-check);
  }

  /* Form */
  .service-form {
    background-color: var(--service-form-bg);
    backdrop-filter: blur(12px);
    border-radius: 1rem;
    border: 1px solid var(--service-form-border);
    padding: 2rem;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
  }
  .service-form-title {
    color: var(--service-form-title);
  }
  .service-form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    background-color: var(--service-form-input-bg);
    border: 1px solid var(--service-form-input-border);
    color: var(--service-form-input-text);
  }
  .service-form-input::placeholder {
    color: var(--service-form-input-placeholder);
  }
  .service-form-input:focus {
    outline: none;
    ring: 2px;
    ring-color: var(--service-form-input-border);
  }
  .service-form-button {
    width: 100%;
    background: linear-gradient(
      to right,
      var(--service-form-button-from),
      var(--service-form-button-to)
    );
    color: white;
    padding: 1rem 1.5rem;
    border-radius: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    transform: scale(1);
    transition: all 0.3s;
  }
  .service-form-button:hover {
    background: linear-gradient(
      to right,
      var(--service-form-button-hover-from),
      var(--service-form-button-hover-to)
    );
    transform: scale(1.02);
  }

  /* Success Message */
  .service-success-icon {
    color: var(--service-success-icon);
  }
  .service-success-title {
    color: var(--service-success-title);
  }
  .service-success-text {
    color: var(--service-success-text);
  }

  .service-form-button:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .extra-option-icon {
    margin-bottom: 12%;
  }

  .loader {
    width: 20px;
    height: 20px;
    border: 2px solid #ffffff;
    border-bottom-color: transparent;
    border-radius: 50%;
    display: inline-block;
    animation: rotation 1s linear infinite;
  }

  @keyframes rotation {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }

  /* Animation */
  .animate-fade-in {
    animation: fadeIn 0.5s ease-in;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script define:vars={{ formId }}>
  document.addEventListener("DOMContentLoaded", function () {
    const forms = document.querySelectorAll("form");
    const formContainer = document.getElementById("formContainer");
    const successMessage = document.getElementById("successMessage");
    let isSubmitting = false;

    forms.forEach((form) => {
      const submitButton = form.querySelector('button[type="submit"]');

      form.addEventListener("submit", async function (event) {
        event.preventDefault();

        if (isSubmitting) return;
        isSubmitting = true;
        submitButton.disabled = true;

        // Récupère le service depuis l'URL
        const path = window.location.pathname;
        const serviceSlug = path.split("/").pop();

        const formData = new FormData(form);
        const formObject = {
          name: formData.get("name"),
          surname: formData.get("surname"),
          email: formData.get("email"),
          phone: formData.get("phone"),
          message: formData.get("message"),
          service: serviceSlug, // Ajoute le service aux données
        };

        try {
          const response = await fetch("/api/send-email", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(formObject),
          });

          const result = await response.json();

          if (response.ok) {
            if (formContainer && successMessage) {
              formContainer.classList.add("hidden");
              successMessage.classList.remove("hidden");
              successMessage.classList.add("animate-fade-in");
            }
          } else {
            throw new Error(result.error || "Une erreur est survenue");
          }
        } catch (error) {
          console.error("Error:", error);
          alert("Une erreur est survenue lors de l'envoi du message.");
        } finally {
          isSubmitting = false;
          submitButton.disabled = false;
        }
      });
    });
  });
</script>
