---
import { getLangFromUrl } from "../../i18n/utils";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import Hero from "../../components/Hero.astro";
import { FaArrowRight, FaCheckCircle } from "react-icons/fa";

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout
  title="Devis Personnalisé | Léo Hengebaert"
  description="Demandez un devis personnalisé pour votre projet."
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Demandez votre devis personnalisé"
        tagline="Donnons vie à votre projet"
        align="center"
      />
      <div
        class="mx-auto px-4 sm:px-6 lg:px-8 py-12 bg-white/10 backdrop-blur-lg rounded-2xl shadow-xl"
      >
        <form id="contactForm" class="space-y-6">
          <!-- Informations de base -->
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              name="name"
              placeholder="Votre Nom*"
              required
              class="col-span-1 w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
            />
            <input
              type="email"
              name="email"
              placeholder="Email*"
              required
              class="col-span-1 w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
            />
          </div>

          <!-- Informations de contact optionnelles -->
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              name="companyName"
              placeholder="Nom de l'entreprise (si applicable)"
              class="col-span-1 w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
            />
            <input
              type="tel"
              name="phone"
              placeholder="Numéro de téléphone (optionnel)"
              class="col-span-1 w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
            />
          </div>

          <!-- Type de projet -->
          <select
            name="projectType"
            required
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
          >
            <option value="">Type de Projet*</option>
            <option value="website">Création de Site Web</option>
            <option value="webapp">Application Web</option>
            <option value="ecommerce">E-commerce</option>
            <option value="redesign">Refonte de Site Web</option>
            <option value="other">Autre</option>
          </select>

          <!-- Détails du projet -->
          <textarea
            name="projectDescription"
            placeholder="Décrivez votre projet et ses objectifs principaux*"
            required
            rows="4"
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all resize-none"
          ></textarea>

          <!-- Public cible -->
          <textarea
            name="targetAudience"
            placeholder="Qui est votre public cible ? (tranche d'âge, centres d'intérêt, besoins)*"
            required
            rows="3"
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all resize-none"
          ></textarea>

          <!-- Fonctionnalités -->
          <textarea
            name="features"
            placeholder="Quelles fonctionnalités clés souhaitez-vous intégrer ?*"
            required
            rows="4"
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all resize-none"
          ></textarea>

          <!-- Préférences de design -->
          <textarea
            name="designPreferences"
            placeholder="Avez-vous des préférences de design particulières ? (style, couleurs, exemples de sites que vous aimez)"
            rows="3"
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all resize-none"
          ></textarea>

          <!-- Contenu -->
          <div class="space-y-3">
            <p class="text-white text-sm">État du contenu*</p>
            <div class="flex gap-4">
              <label class="flex items-center gap-2 text-white">
                <input
                  type="radio"
                  name="contentStatus"
                  value="ready"
                  required
                />
                <span>J'ai le contenu prêt</span>
              </label>
              <label class="flex items-center gap-2 text-white">
                <input
                  type="radio"
                  name="contentStatus"
                  value="partial"
                  required
                />
                <span>J'ai besoin d'aide partielle</span>
              </label>
              <label class="flex items-center gap-2 text-white">
                <input
                  type="radio"
                  name="contentStatus"
                  value="need"
                  required
                />
                <span>J'ai besoin d'aide pour le contenu</span>
              </label>
            </div>
          </div>

          <!-- Délais et Budget -->
          <div class="grid grid-cols-2 gap-4">
            <select
              name="timeline"
              required
              class="col-span-1 w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
            >
              <option value="">Délai souhaité*</option>
              <option value="asap">Dès que possible</option>
              <option value="1-2">1-2 mois</option>
              <option value="2-3">2-3 mois</option>
              <option value="3-6">3-6 mois</option>
              <option value="flexible">Flexible</option>
            </select>

            <select
              name="budget"
              required
              class="col-span-1 w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
            >
              <option value="">Budget prévu*</option>
              <option value="<5k">Moins de 5k€</option>
              <option value="5k-10k">5k€ - 10k€</option>
              <option value="10k-20k">10k€ - 20k€</option>
              <option value="20k+">Plus de 20k€</option>
              <option value="unknown">J'ai besoin de conseils</option>
            </select>
          </div>

          <!-- Informations supplémentaires -->
          <textarea
            name="additionalInfo"
            placeholder="Avez-vous d'autres informations ou des besoins spécifiques à partager ?"
            rows="3"
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all resize-none"
          ></textarea>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-purple-500 to-indigo-600 text-white py-4 px-6 rounded-lg hover:from-purple-600 hover:to-indigo-700 transition-all duration-300 flex items-center justify-center gap-2"
          >
            <span>Envoyer la demande de devis</span>
            <FaArrowRight />
          </button>
        </form>

        <!-- Message de succès (caché par défaut) -->
        <div id="successMessage" class="hidden">
          <div class="text-center py-8 space-y-4">
            <FaCheckCircle className="text-green-400 w-16 h-16 mx-auto" />
            <h3 class="text-2xl font-bold text-white">
              Demande envoyée avec succès !
            </h3>
            <p class="text-purple-200">
              Merci pour ces informations. J'examinerai attentivement les
              détails de votre projet et vous enverrai un devis personnalisé
              sous 48 heures.
            </p>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("contactForm") as HTMLFormElement; // Cast to HTMLFormElement
    const successMessage = document.getElementById("successMessage");
    const errorMessage = document.getElementById("errorMessage");

    if (form) {
      // Check if the form exists
      form.addEventListener("submit", async function (event) {
        event.preventDefault();
        const formData = new FormData(form);
        const formObject = {
          name: formData.get("name"),
          surname: formData.get("surname"),
          email: formData.get("email"),
          message: formData.get("message"),
        };

        try {
          const response = await fetch("/api/send-email", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(formObject),
          });

          if (response.ok) {
            // Hide the form and show the success message
            form.classList.add("hidden");
            if (successMessage) {
              successMessage.classList.remove("hidden");
            }
            if (errorMessage) {
              errorMessage.classList.add("hidden");
            }
            form.reset(); // Réinitialiser le formulaire
          } else {
            const result = await response.json();
            throw new Error(result.error || "Une erreur est survenue");
          }
        } catch (error) {
          console.error("Error:", error);
          if (errorMessage) {
            errorMessage.classList.remove("hidden");
          }
          if (successMessage) {
            successMessage.classList.add("hidden");
          }
        }
      });
    } else {
      console.error("Form not found");
    }
  });
</script>
