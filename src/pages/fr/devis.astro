---
import { getLangFromUrl } from "../../i18n/utils";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import Hero from "../../components/Hero.astro";
import { FaArrowRight, FaCheckCircle } from "react-icons/fa";

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout
  title="Devis Personnalisé | Léo Hengebaert"
  description="Demandez un devis personnalisé pour votre projet."
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Demandez votre devis personnalisé"
        tagline="Donnons vie à votre projet"
        align="center"
      />
      <div
        class="form-bg-container mx-auto px-4 sm:px-6 lg:px-8 py-12 backdrop-blur-lg rounded-2xl shadow-xl"
      >
        <form id="contactForm" class="space-y-6">
          <!-- Informations de base -->
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              name="name"
              placeholder="Votre Nom*"
              required
              class="form-input"
            />
            <input
              type="email"
              name="email"
              placeholder="Email*"
              required
              class="form-input"
            />
          </div>

          <!-- Informations de contact optionnelles -->
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              name="companyName"
              placeholder="Nom de l'entreprise (si applicable)"
              class="form-input"
            />
            <input
              type="tel"
              name="phone"
              placeholder="Numéro de téléphone (optionnel)"
              class="form-input"
            />
          </div>

          <!-- Type de projet -->
          <select name="projectType" required class="form-select">
            <option value="">Type de Projet*</option>
            <option value="website">Création de Site Web</option>
            <option value="webapp">Application Web</option>
            <option value="ecommerce">E-commerce</option>
            <option value="redesign">Refonte de Site Web</option>
            <option value="other">Autre</option>
          </select>

          <!-- Détails du projet -->
          <textarea
            name="projectDescription"
            placeholder="Décrivez votre projet et ses objectifs principaux*"
            required
            rows="4"
            class="form-textarea"></textarea>

          <!-- Public cible -->
          <textarea
            name="targetAudience"
            placeholder="Qui est votre public cible ? (tranche d'âge, centres d'intérêt, besoins)*"
            required
            rows="3"
            class="form-textarea"></textarea>

          <!-- Fonctionnalités -->
          <textarea
            name="features"
            placeholder="Quelles fonctionnalités clés souhaitez-vous intégrer ?*"
            required
            rows="4"
            class="form-textarea"></textarea>

          <!-- Préférences de design -->
          <textarea
            name="designPreferences"
            placeholder="Avez-vous des préférences de design particulières ? (style, couleurs, exemples de sites que vous aimez)"
            rows="3"
            class="form-textarea"></textarea>

          <!-- Contenu -->
          <div class="space-y-3">
            <p class="form-label">État du contenu*</p>
            <div class="flex gap-4">
              <label class="form-radio-label">
                <input
                  type="radio"
                  name="contentStatus"
                  value="ready"
                  required
                />
                <span>J'ai le contenu prêt</span>
              </label>
              <label class="form-radio-label">
                <input
                  type="radio"
                  name="contentStatus"
                  value="partial"
                  required
                />
                <span>J'ai besoin d'aide partielle</span>
              </label>
              <label class="form-radio-label">
                <input
                  type="radio"
                  name="contentStatus"
                  value="need"
                  required
                />
                <span>J'ai besoin d'aide pour le contenu</span>
              </label>
            </div>
          </div>

          <!-- Délais et Budget -->
          <div class="grid grid-cols-2 gap-4">
            <select name="timeline" required class="form-select">
              <option value="">Délai souhaité*</option>
              <option value="asap">Dès que possible</option>
              <option value="1-2">1-2 mois</option>
              <option value="2-3">2-3 mois</option>
              <option value="3-6">3-6 mois</option>
              <option value="flexible">Flexible</option>
            </select>

            <select name="budget" required class="form-select">
              <option value="">Budget prévu*</option>
              <option value="<5k">Moins de 5k€</option>
              <option value="5k-10k">5k€ - 10k€</option>
              <option value="10k-20k">10k€ - 20k€</option>
              <option value="20k+">Plus de 20k€</option>
              <option value="unknown">J'ai besoin de conseils</option>
            </select>
          </div>

          <!-- Informations supplémentaires -->
          <textarea
            name="additionalInfo"
            placeholder="Avez-vous d'autres informations ou des besoins spécifiques à partager ?"
            rows="3"
            class="form-textarea"></textarea>

          <button type="submit" class="form-button">
            <span>Envoyer la demande de devis</span>
            <FaArrowRight />
          </button>
        </form>

        <!-- Message de succès -->
        <div id="successMessage" class="hidden">
          <div class="text-center py-8 space-y-4">
            <FaCheckCircle className="success-icon" />
            <h3 class="success-title">Demande envoyée avec succès !</h3>
            <p class="success-message">
              Merci pour ces informations. J'examinerai attentivement les
              détails de votre projet et vous enverrai un devis personnalisé
              sous 48 heures.
            </p>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    background-color: var(--form-bg);
    border: 1px solid var(--form-border);
    color: var(--form-text);
    transition: all 0.2s ease-in-out;
  }

  .form-bg-container {
    background-color: var(--form-bg-container);
    border: 1px solid var(--form-container-border);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--form-placeholder);
  }

  .form-input:focus,
  .form-select:focus,
  .form-textarea:focus {
    outline: none;
    ring: 2px;
    ring-color: var(--form-ring);
  }

  .form-label {
    color: var(--form-text);
    font-size: 0.875rem;
  }

  .form-radio-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--form-text);
  }

  .form-button {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    border-radius: 0.5rem;
    background: linear-gradient(
      to right,
      var(--form-button-from),
      var(--form-button-to)
    );
    color: var(--form-button-text);
    transition: all 0.3s ease;
  }

  .form-button:hover {
    background: linear-gradient(
      to right,
      var(--form-button-hover-from),
      var(--form-button-hover-to)
    );
  }

  .success-icon {
    color: var(--form-success-icon);
    width: 4rem;
    height: 4rem;
    margin: 0 auto;
  }

  .success-title {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--form-text);
  }

  .success-message {
    color: var(--form-success-text);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("contactForm") as HTMLFormElement; // Cast to HTMLFormElement
    const successMessage = document.getElementById("successMessage");
    const errorMessage = document.getElementById("errorMessage");

    if (form) {
      // Check if the form exists
      form.addEventListener("submit", async function (event) {
        event.preventDefault();
        const formData = new FormData(form);
        const formObject = {
          name: formData.get("name"),
          surname: formData.get("surname"),
          email: formData.get("email"),
          message: formData.get("message"),
        };

        try {
          const response = await fetch("/api/send-email", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(formObject),
          });

          if (response.ok) {
            // Hide the form and show the success message
            form.classList.add("hidden");
            if (successMessage) {
              successMessage.classList.remove("hidden");
            }
            if (errorMessage) {
              errorMessage.classList.add("hidden");
            }
            form.reset(); // Réinitialiser le formulaire
          } else {
            const result = await response.json();
            throw new Error(result.error || "Une erreur est survenue");
          }
        } catch (error) {
          console.error("Error:", error);
          if (errorMessage) {
            errorMessage.classList.remove("hidden");
          }
          if (successMessage) {
            successMessage.classList.add("hidden");
          }
        }
      });
    } else {
      console.error("Form not found");
    }
  });
</script>
