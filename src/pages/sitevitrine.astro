  description="Learn about Léo Hengebaert's most recent projects"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <div class="center-main">
        <Hero
          title="Site Vitrine"
          tagline="What will you have with the offer 'Site Vitrine' ?"
        />
      </div>
      <SiteVitrine />
    </main>
    <ContactCTA />
  </div>
</BaseLayout>

