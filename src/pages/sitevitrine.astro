import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";

import SiteVitrine from "../components/SiteVitrine.astro";
---

<BaseLayout
