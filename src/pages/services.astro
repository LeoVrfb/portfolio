---
import { getCollection } from "astro:content";

import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
import ServiceList from "../components/ServiceList.astro";

const services = (await getCollection("service")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout
  title="My Services | Léo Hengebaert"
  description="Learn about Léo Hengebaert's different offers to select the one that suits your needs"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="My Services"
        tagline="Check my different offers to select the one that suits your needs"
        align="center"
      />
      <ServiceList services={services} />
    </main>
    <ContactCTA />
  </div>
</BaseLayout>
