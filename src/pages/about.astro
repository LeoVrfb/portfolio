---
import BaseLayout from "../layouts/BaseLayout.astro";

import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";
export const prerender = true;
---

<BaseLayout title="About | Léo Hengebaert" description="About Léo Hengebaert">
  <div class="stack gap-20">
    <main class="wrapper about">
      <Hero
        title="About"
        tagline="Thanks for stopping by. Read below to learn more about myself and my background."
      >
        <img
          width="1553"
          height="873"
          src="/assets/portraitLeo.jpg"
          alt="Leo Hengebaert at work"
        />
      </Hero>

      <section>
        <h2 class="section-title">About me</h2>
        <div class="content">
          <p>
            Hi there! I'm Léo Hengebaert, a front-end developer based in Paris.
            I'm proud to currently work at Artefact, one of Europe's leading
            marketing and digital transformation consulting firms. Specializing
            in Artificial Intelligence (AI) and Data, Artefact delivers
            exceptional solutions to clients (LVMH, L'Oréal, Orange, SNCF, and
            many others...) to tackle the most complex challenges in the digital
            world.
          </p>
          <p>
            With a diverse team of passionate talents, Artefact has created a
            future-friendly advertising agency called Artefact 3000. This led me
            to join Artefact 3000's studio, a treasure trove for web artists,
            where designers and developers can unleash their digital potential
            to the fullest.
          </p>
          <p>
            Before joining Artefact, I had the privilege of working at Qare, an
            innovative company in the field of telemedicine and a major player
            in online healthcare. At Qare, I contributed to developing solutions
            that make access to healthcare easier for everyone, a mission that
            deeply resonates with my personal values.
          </p>
          <p>
            As a tech professional, I'm driven by a constant desire to learn and
            improve. My vision is one where technology enriches and enhances
            everyone's lives, where innovation is synonymous with inclusion and
            progress. My dedication to my work is reflected in every line of
            code I write, in every project I undertake.
          </p>
          <p>
            With a unique blend of experience at industry leaders like Artefact
            and Qare, I'm ready to tackle the most complex challenges and strive
            to shape the future of the web as best I can. Join me in this
            exciting adventure where technology meets creativity to create a
            better world, one project at a time.
          </p>
          <br />
        </div>
      </section>
      <section>
        <h2 class="section-title">Education</h2>
        <div class="content">
          <p>
            Web design training at CEFII (Center for Study and Training in
            Computer Science and Internet) - RNCP level 5
          </p>
        </div>
      </section>
      <section>
        <h2 class="section-title">My Skills</h2>
        <div class="content">
          <ol>
            <li>
              Main Technical Skills:
              <ul>
                <li>Programming Languages: JavaScript, TypeScript</li>
                <li>Frameworks and Libraries: React, Next</li>
                <li>Development Tools: Git, Github, Gitlab</li>
                <li>
                  Testing and Debugging: Jest, React Testing Library, Cypress
                </li>
              </ul>
            </li>
            <li>
              Main Professional Skills:
              <ul>
                <li>
                  Project Management: Agile/Scrum, sprint management,
                  estimation, review, planning. Jira, Confluence, Slack.
                </li>
                <li>
                  Teamwork: Experience working in agile teams with developers,
                  designers, PO.
                </li>
                <li>
                  Problem Solving: Ability to effectively solve technical
                  problems.
                </li>
                <li>
                  Creativity: Ability to bring creative ideas to projects.
                </li>
              </ul>
            </li>
            <li>
              Languages:
              <ul>
                <li>French: Native language.</li>
                <li>English: Fluent (reading, writing, speaking).</li>
              </ul>
            </li>
          </ol>
        </div>
      </section>
    </main>

    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .about {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem;
  }

  /* Hero Section */
  img {
    width: 100%;
    height: 500px;
    object-fit: cover;
    border-radius: 24px;
    margin: 2rem 0;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  /* Content Grid Layout */
  .content-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 4rem;
    margin-top: 6rem;
  }

  section {
    grid-column: span 12;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border-radius: 24px;
    padding: 3rem;
    transition: all 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
    margin-bottom: 3%;
  }

  /* Modern gradient backgrounds for sections */
  section:nth-child(1) {
    background: linear-gradient(
      145deg,
      rgba(79, 70, 229, 0.1),
      rgba(0, 0, 0, 0)
    );
  }
  section:nth-child(2) {
    background: linear-gradient(
      145deg,
      rgba(236, 72, 153, 0.1),
      rgba(0, 0, 0, 0)
    );
  }
  section:nth-child(3) {
    background: linear-gradient(
      145deg,
      rgba(34, 211, 238, 0.1),
      rgba(0, 0, 0, 0)
    );
  }
  section:nth-child(4) {
    background: linear-gradient(
      145deg,
      rgba(16, 185, 129, 0.1),
      rgba(0, 0, 0, 0)
    );
  }

  /* Section Title Styling */
  .section-title {
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 2rem;
    position: relative;
    display: inline-block;
  }

  /* Different gradients for each section title */
  section:nth-child(1) .section-title {
    background: linear-gradient(90deg, #4f46e5, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  section:nth-child(2) .section-title {
    background: linear-gradient(90deg, #ec4899, #f472b6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  section:nth-child(3) .section-title {
    background: linear-gradient(90deg, #22d3ee, #67e8f9);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  section:nth-child(4) .section-title {
    background: linear-gradient(90deg, #10b981, #34d399);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Decorative line under titles */
  .section-title::after {
    content: "";
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 60px;
    height: 4px;
    border-radius: 2px;
  }

  section:nth-child(1) .section-title::after {
    background: #4f46e5;
  }
  section:nth-child(2) .section-title::after {
    background: #ec4899;
  }
  section:nth-child(3) .section-title::after {
    background: #22d3ee;
  }
  section:nth-child(4) .section-title::after {
    background: #10b981;
  }

  /* Content Styling */
  .content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--gray-200);
  }

  .content p {
    margin-bottom: 1.8rem;
  }

  /* Skills Layout */
  .skills-grid {
    display: grid;
    gap: 2rem;
  }

  .skills-grid ol {
    list-style: none;
    padding: 0;
  }

  .skills-grid li {
    margin-bottom: 2rem;
  }

  .skills-grid ul {
    margin-top: 0.8rem;
    padding-left: 1.5rem;
  }

  .skills-grid ul li {
    margin-bottom: 0.8rem;
    position: relative;
  }

  .skills-grid ul li::before {
    content: "→";
    position: absolute;
    left: -1.5rem;
    color: #22d3ee;
  }

  /* Desktop Layout */
  @media (min-width: 1024px) {
    section {
      grid-column: 3 / span 8;
    }

    .about {
      padding: 4rem;
    }

    section:hover {
      transform: translateY(-5px);
      box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
    }

    /* Alternating sections layout */
    section:nth-child(odd) {
      grid-column: 2 / span 6;
    }

    section:nth-child(even) {
      grid-column: 6 / span 6;
    }
  }

  /* Tablet Layout */
  @media (min-width: 768px) and (max-width: 1023px) {
    section {
      grid-column: 2 / span 10;
    }

    .about {
      padding: 3rem;
    }
  }

  /* Mobile Layout */
  @media (max-width: 767px) {
    .about {
      padding: 1rem;
    }

    img {
      height: 300px;
    }

    .section-title {
      font-size: 2.2rem;
    }

    section {
      padding: 2rem;
    }

    .content-grid {
      gap: 3rem;
    }
  }

  /* Animation for content loading */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  section {
    animation: fadeIn 0.8s ease-out forwards;
  }

  section:nth-child(2) {
    animation-delay: 0.3s;
  }
  section:nth-child(3) {
    animation-delay: 0.6s;
  }
  section:nth-child(4) {
    animation-delay: 0.9s;
  }
</style>
