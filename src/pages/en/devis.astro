---
import { getLangFromUrl } from "../../i18n/utils";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import Hero from "../../components/Hero.astro";
import { FaArrowRight, FaCheckCircle } from "react-icons/fa";

const lang = getLangFromUrl(Astro.url);
---

<BaseLayout
  title="Custom Quote | Léo Hengebaert"
  description="Request a custom quote for your project."
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Request your custom quote"
        tagline="Let's bring your project to life"
        align="center"
      />
      <div
        class="form-bg-container mx-auto px-4 sm:px-6 lg:px-8 py-12 backdrop-blur-lg rounded-2xl shadow-xl"
      >
        <form id="contactForm" class="space-y-6">
          <!-- Basic Information -->
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              name="name"
              placeholder="Your Name*"
              required
              class="form-input"
            />
            <input
              type="email"
              name="email"
              placeholder="Email*"
              required
              class="form-input"
            />
          </div>

          <!-- Optional Contact Information -->
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              name="companyName"
              placeholder="Company Name (if applicable)"
              class="form-input"
            />
            <input
              type="tel"
              name="phone"
              placeholder="Phone Number (optional)"
              class="form-input"
            />
          </div>

          <!-- Project Type -->
          <select name="projectType" required class="form-select">
            <option value="">Project Type*</option>
            <option value="website">Website Creation</option>
            <option value="webapp">Web Application</option>
            <option value="ecommerce">E-commerce</option>
            <option value="redesign">Website Redesign</option>
            <option value="other">Other</option>
          </select>

          <!-- Project Details -->
          <textarea
            name="projectDescription"
            placeholder="Describe your project and its main objectives*"
            required
            rows="4"
            class="form-textarea"></textarea>

          <!-- Target Audience -->
          <textarea
            name="targetAudience"
            placeholder="Who is your target audience? (age range, interests, needs)*"
            required
            rows="3"
            class="form-textarea"></textarea>

          <!-- Features -->
          <textarea
            name="features"
            placeholder="What key features would you like to include?*"
            required
            rows="4"
            class="form-textarea"></textarea>

          <!-- Design Preferences -->
          <textarea
            name="designPreferences"
            placeholder="Do you have any specific design preferences? (style, colors, websites you like)"
            rows="3"
            class="form-textarea"></textarea>

          <!-- Content -->
          <div class="space-y-3">
            <p class="text-sm">Content Status*</p>
            <div class="flex gap-4">
              <label class="flex items-center gap-2">
                <input
                  type="radio"
                  name="contentStatus"
                  value="ready"
                  required
                />
                <span>I have the content ready</span>
              </label>
              <label class="flex items-center gap-2">
                <input
                  type="radio"
                  name="contentStatus"
                  value="partial"
                  required
                />
                <span>I need partial help</span>
              </label>
              <label class="flex items-center gap-2">
                <input
                  type="radio"
                  name="contentStatus"
                  value="need"
                  required
                />
                <span>I need help with content</span>
              </label>
            </div>
          </div>

          <!-- Timeline and Budget -->
          <div class="grid grid-cols-2 gap-4">
            <select name="timeline" required class="form-select">
              <option value="">Desired Timeline*</option>
              <option value="asap">As soon as possible</option>
              <option value="1-2">1-2 months</option>
              <option value="2-3">2-3 months</option>
              <option value="3-6">3-6 months</option>
              <option value="flexible">Flexible</option>
            </select>

            <select name="budget" required class="form-select">
              <option value="">Expected Budget*</option>
              <option value="<5k">Less than €5k</option>
              <option value="5k-10k">€5k - €10k</option>
              <option value="10k-20k">€10k - €20k</option>
              <option value="20k+">More than €20k</option>
              <option value="unknown">I need guidance</option>
            </select>
          </div>

          <!-- Additional Information -->
          <textarea
            name="additionalInfo"
            placeholder="Do you have any other information or specific needs to share?"
            rows="3"
            class="form-textarea"></textarea>

          <button type="submit" class="form-button">
            <span>Send quote request</span>
            <FaArrowRight />
          </button>
        </form>

        <!-- Success Message -->
        <div id="successMessage" class="hidden">
          <div class="text-center py-8 space-y-4">
            <FaCheckCircle className="success-icon" />
            <h3 class="success-title">Request sent successfully!</h3>
            <p class="success-message">
              Thank you for the information. I will carefully review your
              project details and send you a custom quote within 48 hours.
            </p>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .form-bg-container {
    background-color: var(--form-bg-container);
    border: 1px solid var(--form-container-border);
  }

  .form-input,
  .form-select,
  .form-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    background-color: var(--form-bg);
    border: 1px solid var(--form-border);
    color: var(--form-text);
    transition: all 0.2s ease-in-out;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--form-placeholder);
  }

  .form-button {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    border-radius: 0.5rem;
    background: linear-gradient(
      to right,
      var(--form-button-from),
      var(--form-button-to)
    );
    color: var(--form-button-text);
    transition: all 0.3s ease;
  }

  .form-button:hover {
    background: linear-gradient(
      to right,
      var(--form-button-hover-from),
      var(--form-button-hover-to)
    );
  }

  .success-icon {
    color: var(--form-success-icon);
  }

  .success-title {
    color: var(--form-text);
  }

  .success-message {
    color: var(--form-success-text);
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById("contactForm") as HTMLFormElement; // Cast to HTMLFormElement
    const successMessage = document.getElementById("successMessage");
    const errorMessage = document.getElementById("errorMessage");

    if (form) {
      // Check if the form exists
      form.addEventListener("submit", async function (event) {
        event.preventDefault();
        const formData = new FormData(form);
        const formObject = {
          name: formData.get("name"),
          surname: formData.get("surname"),
          email: formData.get("email"),
          message: formData.get("message"),
        };

        try {
          const response = await fetch("/api/send-email", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(formObject),
          });

          if (response.ok) {
            // Hide the form and show the success message
            form.classList.add("hidden");
            if (successMessage) {
              successMessage.classList.remove("hidden");
            }
            if (errorMessage) {
              errorMessage.classList.add("hidden");
            }
            form.reset(); // Reset the form
          } else {
            const result = await response.json();
            throw new Error(result.error || "An error occurred");
          }
        } catch (error) {
          console.error("Error:", error);
          if (errorMessage) {
            errorMessage.classList.remove("hidden");
          }
          if (successMessage) {
            successMessage.classList.add("hidden");
          }
        }
      });
    } else {
      console.error("Form not found");
    }
  });
</script>
