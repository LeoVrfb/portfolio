---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title="Contact | Léo Hengebaert"
  description="Contact Léo Hengebaert to discuss your project"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <Hero
        title="Contact"
        tagline="Send me a message to discuss your project"
        align="center"
      />
      <div class="mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <form class="space-y-4">
          <div class="grid grid-cols-2 gap-4">
            <input
              type="text"
              name="name"
              placeholder="First Name*"
              required
              class="col-span-1 w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
            />
            <input
              type="text"
              name="surname"
              placeholder="Last Name*"
              required
              class="col-span-1 w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
            />
          </div>
          <input
            type="email"
            name="email"
            placeholder="Email*"
            required
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all"
          />
          <textarea
            name="message"
            placeholder="Your message*"
            required
            rows="6"
            class="w-full px-4 py-3 rounded-lg bg-white/5 border border-purple-300/20 text-white placeholder-purple-300 focus:outline-none focus:ring-2 focus:ring-purple-400 transition-all resize-none"
          ></textarea>
          <button
            type="submit"
            class="w-full bg-gradient-to-r from-purple-500 to-indigo-600 text-white py-3 px-6 rounded-lg hover:from-purple-600 hover:to-indigo-700 transition-all duration-300"
          >
            Send
          </button>
        </form>
      </div>
    </main>
  </div>
</BaseLayout>
