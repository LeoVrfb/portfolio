---
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import Hero from "../../components/Hero.astro";
import ServiceList from "../../components/ServiceList.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = (
  await getCollection("service", ({ id }) => {
    return id.startsWith(`${lang}/`);
  })
).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title={`${t("services.title")} | Léo Hengebaert`}
  description={t("services.description") as string}
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <div class="wordpress-hero">
        <Hero
          title={t("services.title") as string}
          tagline={t("services.tagline") as string}
          align="center"
        />
      </div>
      <ServiceList services={services} />
    </main>
    <ContactCTA />
  </div>
</BaseLayout>

<style>
  .wordpress-hero :global(.hero) {
    position: relative;
    animation: scaleIn 0.6s cubic-bezier(0.87, 0, 0.13, 1) forwards;
  }

  .wordpress-hero :global(.title) {
    font-size: var(--text-4xl);
    color: var(--gray-0);
    opacity: 0;
    transform: translateY(30px) scale(0.9);
    animation: titleIn 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s forwards;
    text-shadow: 0 0 30px rgba(var(--accent-regular), 0.3);
  }

  .wordpress-hero :global(.title)::before {
    content: "";
    position: absolute;
    width: 0;
    height: 3px;
    bottom: -15px;
    left: 50%;
    background: var(--accent-regular);
    transform: translateX(-50%);
    animation: lineExpand 0.6s ease-out 1s forwards;
  }

  .wordpress-hero :global(.tagline) {
    color: var(--gray-200);
    font-size: var(--text-lg);
    opacity: 0;
    filter: blur(10px);
    animation: taglineIn 0.8s ease-out 0.6s forwards;
    margin-top: 15px;
  }

  @keyframes scaleIn {
    from {
      transform: scale(0.95);
    }
    to {
      transform: scale(1);
    }
  }

  @keyframes titleIn {
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes taglineIn {
    to {
      opacity: 1;
      filter: blur(0);
    }
  }

  @keyframes lineExpand {
    to {
      width: 60px;
    }
  }

  @media (max-width: 50em) {
    .wordpress-hero :global(.title) {
      font-size: var(--text-3xl);
    }
  }

  @media (min-width: 50em) {
    .wordpress-hero :global(.title) {
      font-size: var(--text-5xl);
    }
  }
</style>
