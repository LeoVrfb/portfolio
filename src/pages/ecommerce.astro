---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactCTA from "../components/ContactCTA.astro";
import Hero from "../components/Hero.astro";

import SiteEcommerce from "../components/siteEcommerce.astro";

const projects = (await getCollection("work")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
  title="My services | Léo Hengebaert"
  description="Learn about Léo Hengebaert's most recent projects"
>
  <div class="stack gap-20">
    <main class="wrapper stack gap-8">
      <div class="center-main">
        <Hero
          title="Site e-commerce"
          tagline="What will you have with the offer 'Site e-commerce' ?"
        />
      </div>
      <SiteEcommerce />
    </main>
    <ContactCTA />
  </div>
</BaseLayout>

<style></style>
