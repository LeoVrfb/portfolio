---
import { type CollectionEntry, getCollection } from "astro:content";

import BaseLayout from "../../layouts/BaseLayout.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import Hero from "../../components/Hero.astro";
import Icon from "../../components/Icon.astro";
import Pill from "../../components/Pill.astro";

interface Props {
  entry: CollectionEntry<"service">;
}

export const prerender = true;

export async function getStaticPaths() {
  const services = await getCollection("service");
  return services.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
console.log("entry ?", entry);
const { Content } = await entry.render();
const formId = entry.data.form_id || "contactForm";
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="stack gap-20">
    <div class="stack gap-15">
      <header>
        <div class="wrapper stack gap-2">
          <a class="back-link" href="/services/"
            ><Icon icon="arrow-left" /> Services</a
          >
          <Hero title={entry.data.title} align="center">
            <!-- <div class="details">
              <div class="tags">
                {
                  entry.data.tags &&
                    entry.data.tags.map((t: any) => <Pill>{t}</Pill>)
                }
              </div>
              <p class="description">{entry.data.description}</p> -->
          </Hero>
        </div>
      </header>
    </div>
    <main class="wrapper">
      <!-- <div class="stack gap-10 content">
          {
            entry.data.img && (
              <img src={entry.data.img} alt={entry.data.img_alt || ""} />
            )
          }
          <div class="content">
            <Content />
          </div> -->
      <div class="container"></div>

      <section class="box skills">
        <div class="stack gap-2 lg:gap-4">
          <div class="description_service"></div>
          <form
            action="/submit_form"
            method="post"
            class="callActionForm"
            id={formId}
          >
            <input type="text" name="name" placeholder="Prénom*" required />
            <input type="text" name="surname" placeholder="Nom*" required />
            <input
              type="email"
              name="email"
              placeholder="Adresse Email*"
              required
            />
            <input
              type="tel"
              name="phone"
              placeholder="Numéro de Téléphone*"
              required
            />
            <textarea name="message" placeholder="Message*" required></textarea>

            <button type="submit">Envoyer</button>
          </form>
        </div>
        <div class="description">
          {
            entry.data.service_details.map((detail: any) => (
              <>
                <h5>{detail.title}</h5>
                {detail.content && <p class="whyUse">{detail.content}</p>}
                {detail.list_items && (
                  <ul>
                    {detail.list_items.map((item: any) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                )}
              </>
            ))
          }
        </div>
      </section>
      <!-- Ajoute les autres sections de tarification ici -->
    </main>
  </div>
</BaseLayout>
<ContactCTA />

<script>
  interface FormDataObject {
    name: string;
    surname: string;
    email: string;
    phone: string;
    message: string;
  }
  document.addEventListener("DOMContentLoaded", function () {
    const forms = document.querySelectorAll<HTMLFormElement>(".callActionForm");

    forms.forEach((form) => {
      form.addEventListener("submit", async function (event) {
        event.preventDefault();

        const formData = new FormData(form);
        const formObject: FormDataObject = {
          name: formData.get("name") as string,
          surname: formData.get("surname") as string,
          email: formData.get("email") as string,
          phone: formData.get("phone") as string,
          message: formData.get("message") as string,
        };

        const siteType = form.id.replace("contactForm", ""); // Obtient le type de site à partir de l'ID du formulaire

        try {
          const response = await fetch("/api/send-email", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ ...formObject, siteType }),
          });

          const result = await response.json();
          alert(result.message || result.error);
        } catch (error) {
          console.error("Error:", error);
          alert("Une erreur est survenue lors de l'envoi du message.");
        }
      });
    });
  });
</script>

<style>
  /* Ajoute ce style pour le formulaire */
  .box {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    /* Divise la boîte en deux colonnes égales */
    gap: 2rem; /* Ajoute un espacement entre les colonnes */
    border-radius: 0.75rem;
    background: linear-gradient(135deg, #13072e, #3f2182);
  }
  .callActionForm {
    padding: 2rem;
    background-color: none;
  }

  .callActionForm input,
  .callActionForm textarea {
    width: 100%;
    padding: 1rem;
    margin-bottom: 2rem;
    border: 1px solid #ccc;
    border-radius: 0.5rem;
  }
  .callActionForm textarea {
    font-family: Arial, sans-serif; /* Utilise la police Arial */
    resize: none; /* Empêche l'utilisateur de redimensionner le textarea */
    height: 200px; /* Définit une hauteur par défaut pour le textarea */
  }

  .callActionForm button {
    background-color: #13072e;
    color: #fff;
    padding: 2rem 2.5rem;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    float: right;
    width: 40%;
    float: right;
    margin-right: 0.5rem;
  }

  .callActionForm button:hover {
    background-color: #7a3aa1;
  }

  .description {
    flex: 1;
    padding: 2.5rem; /* Ajoute un espacement entre la description et le formulaire */
  }

  .description ul {
    list-style-type: none; /* Supprime les puces standard */
  }

  .description li {
    margin-left: 1.5em; /* Ajoute une marge à gauche pour le texte */
    position: relative; /* Position relative pour aligner l'icône */
  }

  .description li::before {
    content: "🟢"; /* Utilise l'icône verte comme marqueur */
    color: green; /* Définit la couleur de l'icône */
    position: absolute; /* Position absolue pour l'icône */
    left: -1.5em; /* Décale l'icône vers la gauche */
  }

  .whyEcom {
    margin-left: 1.5em; /* Ajoute une marge à gauche pour le texte */
    position: relative; /* Position relative pour aligner l'icône */
  }

  .whyEcom::before {
    content: "🌟"; /* Utilise l'icône verte comme marqueur */
    color: gold; /* Définit la couleur de l'icône */
    position: absolute; /* Position absolue pour l'icône */
    left: -1.5em; /* Décale l'icône vers la gauche */
  }

  .whyUse {
    margin-left: 2rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }

  .toGet {
    margin-bottom: 1rem;
  }
</style>
